{
        "name": "z-idx",
        "version": "1.0.0",
        "license": "MIT",
        "private": false,
        "sideEffect": false,
        "type": "module",
        "publishConfig": {
                "access": "public"
        },
        "main": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "module": "./dist/index.mjs",
        "exports": {
                ".": {
                        "types": "./dist/index.d.ts",
                        "import": {
                                "types": "./dist/index.d.ts",
                                "default": "./dist/index.mjs"
                        },
                        "module": {
                                "types": "./dist/index.d.ts",
                                "default": "./dist/index.mjs"
                        },
                        "require": "./dist/index.js",
                        "default": "./dist/index.mjs"
                },
                "./*": {
                        "types": "./dist/index.d.ts",
                        "import": {
                                "types": "./dist/index.d.ts",
                                "default": "./dist/index.mjs"
                        },
                        "module": {
                                "types": "./dist/index.d.ts",
                                "default": "./dist/index.mjs"
                        },
                        "require": "./dist/index.js",
                        "default": "./dist/index.mjs"
                }
        },
        "files": [
                "dist/**/*",
                "README.md"
        ],
        "scripts": {
                "dev": "vite",
                "build": "vite build",
                "tsup": "npx tsup",
                "preview": "vite preview",
                "perf": "npx tsc --noEmit --extendedDiagnostics 2>&1 | grep '^Instantiations:'",
                "pub": "npx changeset publish",
                "test": "npx vitest run --coverage"
        },
        "devDependencies": {
                "@changesets/cli": "*",
                "@types/markdown-it": "^14.1.2",
                "@types/react-dom": "^19.2.3",
                "@vitest/coverage-v8": "*",
                "install": "^0.13.0",
                "markdown-it": "^14.1.1",
                "mermaid": "^11.13.0",
                "npm": "^11.11.1",
                "prism-react-renderer": "*",
                "react": "19.2.4",
                "react-dom": "19.2.4",
                "react-live": "4.1.8",
                "tsup": "*",
                "typescript": "~5.9.3",
                "vite": "*",
                "vitest": "*"
        }
}
