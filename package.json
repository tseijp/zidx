{
        "name": "z-idx",
        "version": "1.1.1",
        "license": "MIT",
        "private": false,
        "sideEffect": false,
        "type": "module",
        "publishConfig": {
                "access": "public"
        },
        "bugs": {
                "url": "https://github.com/tseijp/z-idx/issues"
        },
        "repository": "tseijp/z-idx.tsei.jp",
        "homepage": "https://z-idx.tsei.jp",
        "keywords": [
                "z-index",
                "CSS",
                "DAG",
                "topological",
                "TypeScript",
                "React",
                "Vue",
                "UI",
                "design"
        ],
        "main": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "module": "./dist/index.mjs",
        "exports": {
                ".": {
                        "types": "./dist/index.d.ts",
                        "import": {
                                "types": "./dist/index.d.ts",
                                "default": "./dist/index.mjs"
                        },
                        "module": {
                                "types": "./dist/index.d.ts",
                                "default": "./dist/index.mjs"
                        },
                        "require": "./dist/index.js",
                        "default": "./dist/index.mjs"
                },
                "./*": {
                        "types": "./dist/index.d.ts",
                        "import": {
                                "types": "./dist/index.d.ts",
                                "default": "./dist/index.mjs"
                        },
                        "module": {
                                "types": "./dist/index.d.ts",
                                "default": "./dist/index.mjs"
                        },
                        "require": "./dist/index.js",
                        "default": "./dist/index.mjs"
                }
        },
        "files": [
                "packages.json",
                "dist/**/*",
                "README.md"
        ],
        "scripts": {
                "dev": "vite",
                "build": "vite build",
                "tsup": "npx tsup",
                "preview": "vite preview",
                "perf": "npx tsc --noEmit --extendedDiagnostics 2>&1 | grep '^Instantiations:'",
                "pub": "npx changeset publish",
                "test": "npx vitest run --coverage"
        },
        "devDependencies": {
                "@changesets/cli": "*",
                "@types/markdown-it": "^14.1.2",
                "@types/react-dom": "^19.2.3",
                "@vitest/coverage-v8": "*",
                "markdown-it": "^14.1.1",
                "mermaid": "^11.13.0",
                "npm": "^11.11.1",
                "prism-react-renderer": "*",
                "react": "19.2.4",
                "react-dom": "19.2.4",
                "react-live": "4.1.8",
                "tsup": "*",
                "typescript": "~5.9.3",
                "vite": "*",
                "vitest": "*"
        }
}
